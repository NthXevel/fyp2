# Copy this file to secrets.toml for local development.
# On Streamlit Community Cloud, add these in the app's Secrets settings.

ALPACA_API_KEY = "your_alpaca_api_key_here"
ALPACA_SECRET_KEY = "your_alpaca_secret_key_here"
ALPACA_BASE_URL = "https://paper-api.alpaca.markets"

# Preferred: single URL (used if provided)
DATABASE_URL = "postgresql+psycopg2://postgres:postgres@localhost:5432/quantlearn"

# Optional: discrete PostgreSQL settings (used when DATABASE_URL is absent)
POSTGRES_HOST = "localhost"
POSTGRES_PORT = "5432"
POSTGRES_DB = "quantlearn"
POSTGRES_USER = "postgres"
POSTGRES_PASSWORD = "postgres"

# Optional pool tuning
DB_POOL_SIZE = "8"
DB_MAX_OVERFLOW = "16"
DB_POOL_RECYCLE = "1800"
DB_POOL_TIMEOUT = "30"
